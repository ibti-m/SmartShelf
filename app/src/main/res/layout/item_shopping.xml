<?xml version="1.0" encoding="utf-8"?>
<!-- Row for a single shopping list item -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <!-- Item name -->
        <TextView
            android:id="@+id/tv_shopping_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="16sp" />

        <!-- Mark as bought: move to inventory -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_bought"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:text="@string/btn_bought"
            android:textSize="12sp" />

        <!-- Remove from list -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_remove_shopping"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/btn_delete"
            android:textColor="@color/expiring_red"
            android:textSize="12sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
