<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground">

    <!-- Screen title -->
    <TextView
        android:id="@+id/tv_home_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="@string/nav_home"
        android:textSize="24sp"
        android:textStyle="bold" />

    <!-- Section header -->
    <TextView
        android:id="@+id/tv_expiring_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:text="@string/expiring_soon_header"
        android:textSize="16sp"
        android:textColor="@color/expiring_red" />

    <!-- Empty state message (shown when no items are expiring) -->
    <TextView
        android:id="@+id/tv_empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/no_expiring_items"
        android:textSize="14sp"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- List of expiring items -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_expiring_items"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="8dp" />

</LinearLayout>
